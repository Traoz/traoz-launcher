{
  "name": "traoz-launcher",
  "version": "1.0.0",
  "description": "Trident Client",
  "main": "src/main/index.js",
  "scripts": {
    "start": "node_modules\\electron\\dist\\electron.exe .",
    "build": "electron-builder --win --x64",
    "dev": "electron . --dev"
  },
  "build": {
    "appId": "com.traoz.launcher",
    "productName": "Trident Client",
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Trident Client"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "traoz",
      "repo": "traoz-launcher"
    }
  },
  "dependencies": {
    "axios": "^1.6.7",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.1.7",
    "extract-zip": "^2.0.1"
  },
  "devDependencies": {
    "electron": "^25.9.8",
    "electron-builder": "^24.9.1"
  }
}
